{
  "manifest_version": 3,
  "name": "FitCheck",
  "version": "0.5.10",
  "description": "Personalized clothing fit verdicts on Myntra, Ajio, and H&M India.",

  "permissions": ["storage", "sidePanel", "activeTab"],
  "host_permissions": [
    "https://www.myntra.com/*",
    "https://www.ajio.com/*",
    "https://www2.hm.com/*"
  ],

  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.myntra.com/*",
        "https://www.ajio.com/*",
        "https://www2.hm.com/*"
      ],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],

  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },

  "action": {
    "default_title": "Open FitCheck"
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
